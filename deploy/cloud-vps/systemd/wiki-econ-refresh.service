[Unit]
Description=wiki-economics batch refresh
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=wiki-econ
Group=wiki-econ
EnvironmentFile=/etc/wiki-economics.env
WorkingDirectory=/srv/wiki-economics/app/current
ExecStart=/srv/wiki-economics/app/current/deploy/cloud-vps/run-refresh.sh
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=true
PrivateDevices=true
ProtectSystem=full
# Additional kernel-surface and namespace hardening for the batch refresh
# unit. Run `systemd-analyze security wiki-econ-refresh.service` after a
# config change to confirm the score has not regressed.
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
RestrictNamespaces=yes
RestrictRealtime=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
ReadWritePaths=/srv/wiki-economics /etc/wiki-economics /etc/wiki-economics.env

[Install]
WantedBy=multi-user.target
