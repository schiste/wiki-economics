WIKI_ECON_ENV=production
WIKI_ECON_REPO_URL=https://github.com/schiste/wiki-economics.git
WIKI_ECON_REPO_REF=main
WIKI_ECON_APP_ROOT=/srv/wiki-economics/app
WIKI_ECON_APP_RELEASES=/srv/wiki-economics/app/releases
WIKI_ECON_APP_CURRENT=/srv/wiki-economics/app/current
WIKI_ECON_DATA_DIR=/srv/wiki-economics/data
WIKI_ECON_OUTPUT_ROOT=/srv/wiki-economics/output
WIKI_ECON_OUTPUT_RELEASES=/srv/wiki-economics/output/releases
WIKI_ECON_OUTPUT_CURRENT=/srv/wiki-economics/output/current
WIKI_ECON_SITE_ROOT=/srv/wiki-economics/site
WIKI_ECON_SITE_RELEASES=/srv/wiki-economics/site/releases
WIKI_ECON_SITE_CURRENT=/srv/wiki-economics/site/current
WIKI_ECON_SITE_DIST_DIR=/srv/wiki-economics/site/current
WIKI_ECON_STATE_ROOT=/srv/wiki-economics/state
WIKI_ECON_ENABLED_WIKIS_FILE=/etc/wiki-economics/wikis.txt
WIKI_ECON_SERVICE_USER=wiki-econ
# Keep the admin auth values below in deployment secrets and render them onto
# the VPS with deploy/cloud-vps/render-env.sh rather than committing real
# operator addresses or client credentials.
WIKI_ECON_ADMIN_ENABLED=1
WIKI_ECON_ADMIN_AUTH_MODE=oidc
WIKI_ECON_ADMIN_PUBLIC_ORIGIN=https://wiki-economics.example.org
WIKI_ECON_ADMIN_OIDC_ISSUER=https://accounts.google.com
WIKI_ECON_ADMIN_OIDC_CLIENT_ID=change-me
WIKI_ECON_ADMIN_OIDC_CLIENT_SECRET=change-me
WIKI_ECON_ADMIN_OIDC_SCOPES=openid email profile
WIKI_ECON_ADMIN_ALLOWED_EMAILS=alice@example.org,bob@example.org
WIKI_ECON_ADMIN_SESSION_SECRET=replace-with-a-random-32-byte-secret
WIKI_ECON_ADMIN_SECURE_COOKIES=1
WIKI_ECON_ADMIN_API_BASE=/admin-api
